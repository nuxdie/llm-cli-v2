{
  "$schema": "https://cmake.org/cmake/help/latest/_downloads/3e2d73bff478d88a7de0de736ba5e361/schema.json",
  "version": 8,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CPR_CURL_USE_LIBPSL": "OFF"
      }
    },
    {
      "name": "clang-libcxx",
      "hidden": true,
      "inherits": "base",
      "environment": {
        "CC": "clang-18",
        "CXX": "clang++-18"
      },
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "-stdlib=libc++"
      }
    },
    {
      "name": "debug",
      "inherits": "base",
      "displayName": "Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "inherits": "base",
      "displayName": "Release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXE_LINKER_FLAGS_RELEASE": "-s",
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION_RELEASE": "ON"
      }
    },
    {
      "name": "debug-clang",
      "inherits": ["debug", "clang-libcxx"]
    },
    {
      "name": "release-clang",
      "inherits": ["release", "clang-libcxx"]
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "debug-clang",
      "configurePreset": "debug-clang"
    },
    {
      "name": "release-clang",
      "configurePreset": "release-clang"
    }
  ]
}
